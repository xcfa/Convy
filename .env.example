# Copy to `.env` and fill in your real values. `.env` is git-ignored.
# docker-compose reads these and injects them into the container.

# Base URL of your qBittorrent Web UI
QBITTORRENT__URL=https://qbittorrent.example.com

# qBittorrent Web UI credentials
QBITTORRENT__USERNAME=your-username
QBITTORRENT__PASSWORD=your-password

# Poll interval (h:m:s). 0 disables syncing.
QBITTORRENT__SYNCINTERVAL=0:0:5
